# Production / native app API (required for Capacitor builds on a real phone)
# Use your machine LAN IP during testing, e.g. http://172.20.10.4:5000
# VITE_API_URL=http://192.168.1.100:5000

# Optional: live-reload the Vite dev server inside the native app (same Wi‑Fi)
# Set before sync — see frontend/CAPACITOR.md
# CAPACITOR_SERVER_URL=http://192.168.1.100:5174

# Optional: Google Maps Embed API key for venue maps on event details
# Without it, a basic Google Maps embed is used (may have usage limits)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
